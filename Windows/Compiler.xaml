<Window x:Class="Laba1.Windows.Compiler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laba1.Windows"
        mc:Ignorable="d"
        Title="Компилятор"
        Height="720"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Image">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать" Click="Create_Click"/>
                <MenuItem Header="Открыть" Click="Open_Click"/>
                <MenuItem Header="Сохранить" Click="Save_Click"/>
                <MenuItem Header="Сохранить как" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Правка">
                <MenuItem Header="Отменить" Command="Undo"/>
                <MenuItem Header="Повторить" Command="Redo"/>
                <Separator/>
                <MenuItem Header="Вырезать" Command="Cut"/>
                <MenuItem Header="Копировать" Command="Copy"/>
                <MenuItem Header="Вставить" Command="Paste"/>
                <MenuItem Header="Удалить" Command="EditingCommands.Delete"/>
                <Separator/>
                <MenuItem Header="Выделить все" Command="SelectAll"/>
            </MenuItem>

            <MenuItem Header="Текст">
                <MenuItem Header="Постановка задачи"/>
                <MenuItem Header="Грамматика"/>
                <MenuItem Header="Классификация грамматики"/>
                <MenuItem Header="Метод анализа"/>
                <MenuItem Header="Тестовый пример"/>
                <MenuItem Header="Список литературы"/>
                <MenuItem Header="Исходный код программы"/>
            </MenuItem>

            <MenuItem Header="Пуск" Click="RunAnalysis_Click"/>

            <MenuItem Header="Справка">
                <MenuItem Header="Вызов справки" Click="Reference_Click"/>
                <Separator/>
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button ToolTip="Создать" Click="Create_Click">
                    <Image Source="/Images/create.png"/>
                </Button>

                <Button ToolTip="Открыть" Click="Open_Click">
                    <Image Source="/Images/folder.png"/>
                </Button>

                <Button ToolTip="Сохранить" Click="Save_Click">
                    <Image Source="/Images/save.png"/>
                </Button>

                <Separator/>

                <Button ToolTip="Назад" Command="Undo">
                    <Image Source="/Images/left-arrow.png"/>
                </Button>

                <Button ToolTip="Вперед" Command="Redo">
                    <Image Source="/Images/right-arrow.png"/>
                </Button>

                <Separator/>

                <Button ToolTip="Копировать" Command="Copy">
                    <Image Source="/Images/copy.png"/>
                </Button>

                <Button ToolTip="Вырезать" Command="Cut">
                    <Image Source="/Images/cut.png"/>
                </Button>

                <Button ToolTip="Вставить" Command="Paste">
                    <Image Source="/Images/insert.png"/>
                </Button>

                <Separator/>

                <Button ToolTip="Пуск" Click="RunAnalysis_Click">
                    <Image Source="/Images/play.png"/>
                </Button>

                <Button ToolTip="Вызов справки" Click="Reference_Click">
                    <Image Source="/Images/question.png"/>
                </Button>

                <Button ToolTip="О программе" Click="About_Click">
                    <Image Source="/Images/exclamation.png"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="2.4*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Исходный текст" Margin="0,0,0,2">
                <RichTextBox
                    x:Name="FileContentViewer"
                    TextChanged="FileContentViewer_TextChanged"
                    Background="White"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    Padding="6"
                    FontFamily="Consolas"
                    FontSize="14"
                    AcceptsTab="True">

                    <FlowDocument
                        PagePadding="0"
                        LineStackingStrategy="BlockLineHeight"
                        LineHeight="18">
                        <Paragraph Margin="0" Padding="0">
                            <Run Text="Dictionary&lt;int, string&gt; My_dict1 = new Dictionary&lt;int, string&gt; {&#10;    { 1, &quot;one&quot; },&#10;    { 2, &quot;two&quot; },&#10;    { 3, &quot;three&quot; }&#10;};&#10;"/>
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Silver"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

            <GroupBox Grid.Row="2" Header="Результаты лексического анализа" Margin="0,2,0,0">
                <DataGrid
                    x:Name="OutputDataGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    Background="White"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    RowHeaderWidth="0"
                    GridLinesVisibility="Horizontal"
                    AlternatingRowBackground="NavajoWhite"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    SelectionMode="Single"
                    SelectionChanged="OutputDataGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Условный код"
                                            Binding="{Binding Code}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Тип лексемы"
                                            Binding="{Binding TypeName}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Лексема"
                                            Binding="{Binding Lexeme}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Местоположение"
                                            Binding="{Binding Location}"
                                            Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>